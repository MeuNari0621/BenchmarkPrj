{
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "googletest.failed",
                "settings": {
                    "foreground": "#f00"
                }
            },
            {
                "scope": "googletest.passed",
                "settings": {
                    "foreground": "#0f0"
                }
            },
            {
                "scope": "googletest.run",
                "settings": {
                    "foreground": "#0f0"
                }
            }
        ]
    },
    "gtest-adapter.debugConfig": [
        "LightScheduler"
    ],
    "gtest-adapter.supportLocation": true,
    "files.associations": {
        "add.h": "c",
        "*.tcc": "cpp",
        "app.h": "c"
    },
    "testExplorer.addToEditorContextMenu": true,
    "files.encoding": "utf8"
}